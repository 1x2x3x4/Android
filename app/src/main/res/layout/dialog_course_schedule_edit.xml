<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp">

        <TextView
            android:id="@+id/textCourseDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editScheduleTeacher"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="教师"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editScheduleClassroom"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="教室"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editScheduleStartTime"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="课程开始"
            android:inputType="time"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editScheduleEndTime"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="课程结束"
            android:inputType="time"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editScheduleCheckInStart"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="签到开始"
            android:inputType="time"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editScheduleCheckInEnd"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="签到截止"
            android:inputType="time"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editScheduleCheckOutStart"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="签退开始"
            android:inputType="time"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editScheduleCheckOutEnd"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="签退截止"
            android:inputType="time"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchScheduleEnabled"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="启用本课程"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>
</ScrollView>
